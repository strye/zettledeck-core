#!/usr/bin/env bash
# temporal-inventory — Build a time-ordered inventory of vault markdown files
#
# Usage:
#   temporal-inventory <vault-root> [--scope <folder>] [--since <YYYY-MM-DD>] [--until <YYYY-MM-DD>]
#
# Output: TSV to stdout
#   date    file    doctype    status    word_count
#
# Options:
#   --scope <folder>       Restrict search to a subfolder of vault-root.
#                          File paths in output are relative to the scoped folder,
#                          not vault-root.
#   --since <YYYY-MM-DD>   Only include files dated on or after this date
#   --until <YYYY-MM-DD>   Only include files dated on or before this date
#
# Date resolution order:
#   1. Frontmatter 'date' or 'created' field
#   2. Filename date prefix (YYYY-MM-DD)
#   3. File modification time
#
# Frontmatter fields extracted: docType (or doc_type), status
# word_count: approximate (splits on whitespace, excluding frontmatter block)
#
# Used by: nexus temporal, nexus scan, nexus trace, insight align

set -euo pipefail

# ── Arguments ─────────────────────────────────────────────────────────────────

VAULT_ROOT=""
SCOPE=""
SINCE=""
UNTIL=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --scope) SCOPE="$2"; shift 2 ;;
        --since) SINCE="$2"; shift 2 ;;
        --until) UNTIL="$2"; shift 2 ;;
        -*)      echo "Unknown option: $1" >&2; exit 1 ;;
        *)       VAULT_ROOT="$1"; shift ;;
    esac
done

if [[ -z "$VAULT_ROOT" ]]; then
    echo "Usage: temporal-inventory <vault-root> [--scope <folder>] [--since <YYYY-MM-DD>] [--until <YYYY-MM-DD>]" >&2
    exit 1
fi

if [[ ! -d "$VAULT_ROOT" ]]; then
    echo "Error: vault root not found: $VAULT_ROOT" >&2
    exit 1
fi

SEARCH_ROOT="$VAULT_ROOT"
if [[ -n "$SCOPE" ]]; then
    SEARCH_ROOT="$VAULT_ROOT/$SCOPE"
    if [[ ! -d "$SEARCH_ROOT" ]]; then
        echo "Error: scope folder not found: $SEARCH_ROOT" >&2
        exit 1
    fi
fi

# ── Date comparison helper ─────────────────────────────────────────────────────
# Returns 0 if date_a <= date_b (string comparison works for YYYY-MM-DD)
date_lte() { [[ "$1" < "$2" || "$1" == "$2" ]]; }

# ── Frontmatter extraction ─────────────────────────────────────────────────────
# Reads the first 30 lines (enough for frontmatter) and extracts a named field.
# Returns empty string if not found.
extract_frontmatter() {
    local file="$1"
    local field="$2"
    head -30 "$file" \
        | grep -m1 -iE "^${field}[_]?[Tt]?[Yy]?[Pp]?[Ee]?:\s*" \
        | sed -E "s/^[^:]+:[[:space:]]*[\"']?([^\"'#\n]+)[\"']?.*/\1/" \
        | sed 's/[[:space:]]*$//' \
        || true
}

# Simpler single-field extractor (exact key match)
get_frontmatter_field() {
    local file="$1"
    local key="$2"
    head -30 "$file" \
        | grep -m1 -E "^${key}:\s*" \
        | sed -E "s/^${key}:[[:space:]]*[\"']?([^\"'#]+)[\"']?.*/\1/" \
        | sed 's/[[:space:]]*$//' \
        || true
}

# ── Date extraction ────────────────────────────────────────────────────────────
extract_date() {
    local file="$1"
    local date=""

    # 1. Frontmatter date/created
    date=$(head -20 "$file" \
        | grep -m1 -E '^(date|created):\s*' \
        | sed -E 's/^(date|created):\s*"?([0-9]{4}-[0-9]{2}-[0-9]{2}).*/\2/' \
        | grep -E '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' || true)

    # 2. Filename date prefix
    if [[ -z "$date" ]]; then
        date=$(basename "$file" \
            | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}' || true)
    fi

    # 3. File mtime
    if [[ -z "$date" ]]; then
        date=$(date -r "$file" '+%Y-%m-%d' 2>/dev/null || true)
    fi

    echo "${date:-unknown}"
}

# ── Word count (excludes frontmatter block) ────────────────────────────────────
count_words() {
    local file="$1"
    # Skip lines between --- delimiters at top of file (frontmatter)
    awk '
        /^---$/ && NR == 1 { in_fm=1; next }
        /^---$/ && in_fm    { in_fm=0; next }
        !in_fm              { n += NF }
        END                 { print n }
    ' "$file"
}

# ── Header ─────────────────────────────────────────────────────────────────────

printf "date\tfile\tdoctype\tstatus\tword_count\n"

# ── Main ───────────────────────────────────────────────────────────────────────

while IFS= read -r -d '' file; do
    [[ "$file" == *"/.git/"* ]] && continue
    [[ "$file" == *"/assets/"* ]] && continue

    date=$(extract_date "$file")

    # Apply date filters
    if [[ -n "$SINCE" && "$date" != "unknown" ]]; then
        date_lte "$date" "$SINCE" && [[ "$date" != "$SINCE" ]] && continue
    fi
    if [[ -n "$UNTIL" && "$date" != "unknown" ]]; then
        date_lte "$UNTIL" "$date" && [[ "$date" != "$UNTIL" ]] && continue
    fi

    rel_path="${file#$SEARCH_ROOT/}"

    # Extract docType (try both camelCase and snake_case)
    doctype=$(get_frontmatter_field "$file" "docType")
    if [[ -z "$doctype" ]]; then
        doctype=$(get_frontmatter_field "$file" "doc_type")
    fi
    doctype="${doctype:-unknown}"

    status=$(get_frontmatter_field "$file" "status")
    status="${status:-unknown}"

    word_count=$(count_words "$file")

    # Escape tabs in string fields
    safe_file=$(printf '%s' "$rel_path" | tr '\t' ' ')
    safe_doctype=$(printf '%s' "$doctype" | tr '\t' ' ')
    safe_status=$(printf '%s' "$status" | tr '\t' ' ')

    printf '%s\t%s\t%s\t%s\t%s\n' \
        "$date" "$safe_file" "$safe_doctype" "$safe_status" "${word_count:-0}"

done < <(find "$SEARCH_ROOT" -name "*.md" -not -path "*/.git/*" -print0 \
    | sort -z)
