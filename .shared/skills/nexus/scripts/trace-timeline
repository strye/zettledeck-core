#!/usr/bin/env bash
# trace-timeline — Build a chronological mention timeline for a term across the vault
#
# Usage:
#   trace-timeline <vault-root> <primary-term> [synonyms...] [--gap <days>] [--scope <folder>]
#
# Output: TSV to stdout
#   date    file    excerpt    confidence_marker    gap_flag
#
# Options:
#   --gap <days>      Flag dormancy gaps longer than N days (default: 60)
#   --scope <folder>  Restrict search to a subfolder of vault-root (e.g. "Reliquary").
#                     File paths in output are relative to the scoped folder,
#                     not vault-root.
#
# Confidence markers detected: [solid], [evolving], [hypothesis], [questioning]
# Gap flag: "GAP:<N>days" when the silence before this entry exceeds --gap threshold
#
# Used by: nexus trace (Phase 3), nexus scan (Phase 3 per-domain probe)

set -euo pipefail

# ── Arguments ────────────────────────────────────────────────────────────────

VAULT_ROOT=""
TERMS=()
GAP_DAYS=60
SCOPE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --gap)   GAP_DAYS="$2"; shift 2 ;;
        --scope) SCOPE="$2";    shift 2 ;;
        -*)      echo "Unknown option: $1" >&2; exit 1 ;;
        *)
            if [[ -z "$VAULT_ROOT" ]]; then
                VAULT_ROOT="$1"
            else
                TERMS+=("$1")
            fi
            shift
            ;;
    esac
done

if [[ -z "$VAULT_ROOT" ]] || [[ ${#TERMS[@]} -eq 0 ]]; then
    echo "Usage: trace-timeline <vault-root> <primary-term> [synonyms...] [--gap <days>] [--scope <folder>]" >&2
    exit 1
fi

if [[ ! -d "$VAULT_ROOT" ]]; then
    echo "Error: vault root not found: $VAULT_ROOT" >&2
    exit 1
fi

SEARCH_ROOT="$VAULT_ROOT"
if [[ -n "$SCOPE" ]]; then
    SEARCH_ROOT="$VAULT_ROOT/$SCOPE"
    if [[ ! -d "$SEARCH_ROOT" ]]; then
        echo "Error: scope folder not found: $SEARCH_ROOT" >&2
        exit 1
    fi
fi

# ── Date extraction helper ────────────────────────────────────────────────────

extract_date() {
    local file="$1"
    local date=""

    date=$(head -20 "$file" \
        | grep -m1 -E '^(date|created):\s*' \
        | sed -E 's/^(date|created):\s*"?([0-9]{4}-[0-9]{2}-[0-9]{2}).*/\2/' \
        | grep -E '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' || true)

    if [[ -z "$date" ]]; then
        date=$(basename "$file" \
            | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}' || true)
    fi

    if [[ -z "$date" ]]; then
        date=$(date -r "$file" '+%Y-%m-%d' 2>/dev/null || true)
    fi

    echo "${date:-unknown}"
}

# ── Date to epoch helper (for gap calculation) ────────────────────────────────

date_to_epoch() {
    local d="$1"
    # macOS date -j -f; GNU date -d
    if date -j -f '%Y-%m-%d' "$d" '+%s' &>/dev/null 2>&1; then
        date -j -f '%Y-%m-%d' "$d" '+%s'
    else
        date -d "$d" '+%s' 2>/dev/null || echo "0"
    fi
}

# ── Confidence marker detection ───────────────────────────────────────────────

detect_confidence() {
    local line="$1"
    if echo "$line" | grep -qi '\[solid\]';       then echo "[solid]";       return; fi
    if echo "$line" | grep -qi '\[evolving\]';    then echo "[evolving]";    return; fi
    if echo "$line" | grep -qi '\[hypothesis\]';  then echo "[hypothesis]";  return; fi
    if echo "$line" | grep -qi '\[questioning\]'; then echo "[questioning]"; return; fi
    echo ""
}

# ── Collect all matches ───────────────────────────────────────────────────────
# Temp file: date<TAB>file<TAB>excerpt<TAB>confidence

TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

while IFS= read -r -d '' file; do
    [[ "$file" == *"/assets/"* ]] && continue
    [[ "$file" == *"/.git/"*   ]] && continue

    date=$(extract_date "$file")
    [[ "$date" == "unknown" ]] && continue   # skip undatable files

    rel_path="${file#$SEARCH_ROOT/}"

    for term in "${TERMS[@]}"; do
        while IFS= read -r match_line; do
            [[ -z "$match_line" ]] && continue

            line_content="${match_line#*:}"
            excerpt=$(echo "$line_content" | sed 's/^[[:space:]]*//' | tr -s ' ')
            [[ ${#excerpt} -lt 5 ]] && continue

            confidence=$(detect_confidence "$excerpt")

            # Escape tabs in output
            safe_path=$(printf '%s' "$rel_path" | tr '\t' ' ')
            safe_excerpt=$(printf '%s' "$excerpt" | tr '\t' ' ')
            safe_conf=$(printf '%s' "$confidence" | tr '\t' ' ')

            printf '%s\t%s\t%s\t%s\n' \
                "$date" "$safe_path" "$safe_excerpt" "$safe_conf" \
                >> "$TMPFILE"

        done < <(grep -in "$term" "$file" 2>/dev/null || true)
    done

done < <(find "$SEARCH_ROOT" -name "*.md" -not -path "*/.git/*" -print0)

# ── Deduplicate (same date+file+excerpt) and sort chronologically ─────────────

SORTED=$(sort -t$'\t' -k1,1 -k2,2 "$TMPFILE" | sort -u -t$'\t' -k1,1 -k2,2 -k3,3)

# ── Emit with gap flags ───────────────────────────────────────────────────────

printf "date\tfile\texcerpt\tconfidence_marker\tgap_flag\n"

prev_epoch=0
prev_date=""

while IFS=$'\t' read -r date file excerpt confidence; do
    gap_flag=""

    if [[ "$date" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        epoch=$(date_to_epoch "$date")

        if [[ $prev_epoch -gt 0 && $epoch -gt 0 ]]; then
            diff_days=$(( (epoch - prev_epoch) / 86400 ))
            if [[ $diff_days -gt $GAP_DAYS ]]; then
                gap_flag="GAP:${diff_days}days"
            fi
        fi

        prev_epoch=$epoch
        prev_date=$date
    fi

    printf '%s\t%s\t%s\t%s\t%s\n' \
        "$date" "$file" "$excerpt" "$confidence" "$gap_flag"

done <<< "$SORTED"
