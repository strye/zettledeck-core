#!/usr/bin/env bash
# belief-extractor — Extract assertive belief statements from vault markdown files
#
# Usage:
#   belief-extractor <vault-root> [--scope <folder>] [--min-context <n>]
#
# Output: TSV to stdout
#   file    date    marker    belief_sentence
#
# Options:
#   --scope <folder>     Restrict search to a subfolder of vault-root. Accepts
#                        a path relative to vault-root (e.g. "Reliquary").
#                        File paths in output are relative to the scoped folder,
#                        not vault-root.
#   --min-context <n>    Minimum surrounding words to include (default: 0)
#
# Used by: nexus lint (Phase 2c), insight contradictions (Step 1)

set -euo pipefail

# ── Arguments ────────────────────────────────────────────────────────────────

VAULT_ROOT=""
SCOPE=""
MIN_CONTEXT=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --scope)       SCOPE="$2";       shift 2 ;;
        --min-context) MIN_CONTEXT="$2"; shift 2 ;;
        -*)            echo "Unknown option: $1" >&2; exit 1 ;;
        *)             VAULT_ROOT="$1";  shift ;;
    esac
done

if [[ -z "$VAULT_ROOT" ]]; then
    echo "Usage: belief-extractor <vault-root> [--scope <folder>] [--min-context <n>]" >&2
    exit 1
fi

if [[ ! -d "$VAULT_ROOT" ]]; then
    echo "Error: vault root not found: $VAULT_ROOT" >&2
    exit 1
fi

SEARCH_ROOT="$VAULT_ROOT"
if [[ -n "$SCOPE" ]]; then
    SEARCH_ROOT="$VAULT_ROOT/$SCOPE"
    if [[ ! -d "$SEARCH_ROOT" ]]; then
        echo "Error: scope folder not found: $SEARCH_ROOT" >&2
        exit 1
    fi
fi

# ── Belief marker patterns ────────────────────────────────────────────────────
# Ordered from most specific to most general to reduce false positives.

MARKERS=(
    "I believe"
    "I know"
    "the truth is"
    "the real issue is"
    "what matters is"
    "the most important thing"
    "it's obvious that"
    "it is obvious that"
    "without question"
    "without a doubt"
    "clearly,"
    "obviously,"
    "the right way"
    "the only way"
    "you must"
    "you should always"
    "you should never"
    "fundamentally,"
    "X is fundamentally"
    "is fundamentally"
    "at its core,"
    "the key insight"
    "the key is"
)

# ── Date extraction helper ────────────────────────────────────────────────────
# Try frontmatter 'date', 'created', then filename date pattern YYYY-MM-DD.

extract_date() {
    local file="$1"
    local date=""

    # Try frontmatter date/created fields (first 20 lines is enough for frontmatter)
    date=$(head -20 "$file" \
        | grep -m1 -E '^(date|created):\s*' \
        | sed -E 's/^(date|created):\s*"?([0-9]{4}-[0-9]{2}-[0-9]{2}).*/\2/' \
        | grep -E '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' || true)

    # Fall back to filename date pattern
    if [[ -z "$date" ]]; then
        date=$(basename "$file" \
            | grep -oE '^[0-9]{4}-[0-9]{2}-[0-9]{2}' || true)
    fi

    # Fall back to file modification date
    if [[ -z "$date" ]]; then
        date=$(date -r "$file" '+%Y-%m-%d' 2>/dev/null || true)
    fi

    echo "${date:-unknown}"
}

# ── Header ────────────────────────────────────────────────────────────────────

printf "file\tdate\tmarker\tbelief_sentence\n"

# ── Main search ───────────────────────────────────────────────────────────────

while IFS= read -r -d '' file; do
    # Skip frontmatter-only files and non-content files
    [[ "$file" == *"/assets/"* ]] && continue
    [[ "$file" == *"/.git/"*   ]] && continue

    date=$(extract_date "$file")
    rel_path="${file#$SEARCH_ROOT/}"

    for marker in "${MARKERS[@]}"; do
        # Case-insensitive grep; -n for line numbers; skip frontmatter (---)
        while IFS= read -r match; do
            [[ -z "$match" ]] && continue

            # Strip leading line number from grep -n output
            line_content="${match#*:}"

            # Skip lines that are purely YAML frontmatter values
            [[ "$line_content" =~ ^[[:space:]]*--- ]] && continue

            # Clean: collapse whitespace, trim
            sentence=$(echo "$line_content" | sed 's/^[[:space:]]*//' | tr -s ' ')

            # Skip very short matches (likely headers or partial words)
            [[ ${#sentence} -lt 15 ]] && continue

            # Escape tabs in output fields to preserve TSV integrity
            safe_file=$(printf '%s' "$rel_path" | tr '\t' ' ')
            safe_marker=$(printf '%s' "$marker" | tr '\t' ' ')
            safe_sentence=$(printf '%s' "$sentence" | tr '\t' ' ')

            printf '%s\t%s\t%s\t%s\n' \
                "$safe_file" "$date" "$safe_marker" "$safe_sentence"

        done < <(grep -in "$marker" "$file" 2>/dev/null || true)
    done

done < <(find "$SEARCH_ROOT" -name "*.md" -not -path "*/.git/*" -print0)
