#!/usr/bin/env bash
#
# zd — ZettleDeck module composer
#
# Manages installation, linking, and updates of ZettleDeck modules.
# Reads module declarations from zettledeck.yml in the project root.
#
# Usage:
#   zd install          Install all modules declared in zettledeck.yml
#   zd update           Update all installed modules to latest
#   zd link             Re-link skills and agents from installed modules
#   zd status           Show installed modules and their versions
#   zd init             Create a starter zettledeck.yml and project structure
#
# Requirements:
#   - git
#   - yq (https://github.com/mikefarah/yq) for YAML parsing
#     Install: brew install yq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
CONFIG_FILE="${PROJECT_ROOT}/zettledeck.yml"
MODULES_DIR="${PROJECT_ROOT}/.zettledeck/modules"
SHARED_SKILLS="${PROJECT_ROOT}/.shared/skills"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info()  { echo -e "${BLUE}[zd]${NC} $1"; }
log_ok()    { echo -e "${GREEN}[zd]${NC} $1"; }
log_warn()  { echo -e "${YELLOW}[zd]${NC} $1"; }
log_error() { echo -e "${RED}[zd]${NC} $1"; }

# Check dependencies
check_deps() {
    if ! command -v git &> /dev/null; then
        log_error "git is required but not installed."
        exit 1
    fi
    if ! command -v yq &> /dev/null; then
        log_error "yq is required but not installed. Install with: brew install yq"
        exit 1
    fi
}

# Initialize a new project with starter config
cmd_init() {
    if [[ -f "$CONFIG_FILE" ]]; then
        log_warn "zettledeck.yml already exists. Skipping init."
        return
    fi

    mkdir -p "$SHARED_SKILLS"
    mkdir -p "${PROJECT_ROOT}/.claude/agents"

    cat > "$CONFIG_FILE" << 'YAML'
# ZettleDeck Module Configuration
# Add modules to install skills, agents, and templates into this project.
#
# Each module is a git repository containing:
#   skills/     — skill directories to symlink into .shared/skills/
#   agents/     — agent definitions to symlink into .claude/agents/
#   templates/  — files to copy into the project root (vault-steering.md, etc.)

modules:
  - name: zettledeck-core
    repo: github.com/strye/zettledeck-core
    ref: main

  # Uncomment to add more modules:
  # - name: zettledeck-almanac
  #   repo: github.com/strye/zettledeck-almanac
  #   ref: main
  # - name: zettledeck-nexus
  #   repo: github.com/strye/zettledeck-nexus
  #   ref: main
  # - name: zettledeck-foundry
  #   repo: github.com/strye/zettledeck-foundry
  #   ref: main
  # - name: rostrum-blackboard
  #   repo: github.com/strye/rostrum-blackboard
  #   ref: main
YAML

    log_ok "Created zettledeck.yml and project structure."
    log_info "Edit zettledeck.yml to configure your modules, then run: zd install"
}

# Install all modules from zettledeck.yml
cmd_install() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        log_error "No zettledeck.yml found. Run 'zd init' first."
        exit 1
    fi

    check_deps
    mkdir -p "$MODULES_DIR"
    mkdir -p "$SHARED_SKILLS"

    local count
    count=$(yq '.modules | length' "$CONFIG_FILE")

    for ((i=0; i<count; i++)); do
        local name repo ref
        name=$(yq ".modules[$i].name" "$CONFIG_FILE")
        repo=$(yq ".modules[$i].repo" "$CONFIG_FILE")
        ref=$(yq ".modules[$i].ref // \"main\"" "$CONFIG_FILE")

        local module_dir="${MODULES_DIR}/${name}"

        if [[ -d "$module_dir" ]]; then
            log_info "Module '${name}' already installed. Use 'zd update' to refresh."
            continue
        fi

        log_info "Installing ${name} from ${repo} (${ref})..."

        # Clone the module
        git clone --depth 1 --branch "$ref" "https://${repo}.git" "$module_dir" 2>/dev/null || {
            log_error "Failed to clone ${repo}. Check the URL and your access."
            continue
        }

        log_ok "Installed ${name}."
    done

    # Link everything after install
    cmd_link
}

# Create symlinks from installed modules into the project
cmd_link() {
    if [[ ! -d "$MODULES_DIR" ]]; then
        log_error "No modules installed. Run 'zd install' first."
        exit 1
    fi

    mkdir -p "$SHARED_SKILLS"

    local linked=0

    for module_dir in "$MODULES_DIR"/*/; do
        local module_name
        module_name=$(basename "$module_dir")

        # Link skills
        if [[ -d "${module_dir}skills" ]]; then
            for skill_dir in "${module_dir}skills"/*/; do
                local skill_name
                skill_name=$(basename "$skill_dir")
                local target="${SHARED_SKILLS}/${skill_name}"

                if [[ -L "$target" ]]; then
                    rm "$target"  # Remove old symlink to re-link
                elif [[ -d "$target" ]]; then
                    log_warn "Skill '${skill_name}' exists as a directory (not a symlink). Skipping."
                    continue
                fi

                ln -s "$skill_dir" "$target"
                log_info "  Linked skill: ${skill_name} (from ${module_name})"
                ((linked++))
            done
        fi

        # Link agents
        if [[ -d "${module_dir}agents" ]]; then
            mkdir -p "${PROJECT_ROOT}/.claude/agents"
            for agent_file in "${module_dir}agents"/*.md; do
                [[ -f "$agent_file" ]] || continue
                local agent_name
                agent_name=$(basename "$agent_file")
                local target="${PROJECT_ROOT}/.claude/agents/${agent_name}"

                if [[ -L "$target" ]]; then
                    rm "$target"
                elif [[ -f "$target" ]]; then
                    log_warn "Agent '${agent_name}' exists as a file (not a symlink). Skipping."
                    continue
                fi

                ln -s "$agent_file" "$target"
                log_info "  Linked agent: ${agent_name} (from ${module_name})"
                ((linked++))
            done
        fi

        # Copy templates (one-time, don't overwrite)
        if [[ -d "${module_dir}templates" ]]; then
            for template_file in "${module_dir}templates"/*; do
                [[ -f "$template_file" ]] || continue
                local template_name
                template_name=$(basename "$template_file")
                local target="${PROJECT_ROOT}/${template_name}"

                if [[ -f "$target" ]]; then
                    log_info "  Template '${template_name}' already exists. Skipping (won't overwrite)."
                else
                    cp "$template_file" "$target"
                    log_ok "  Copied template: ${template_name}"
                fi
            done
        fi
    done

    log_ok "Linking complete. ${linked} items linked."
}

# Update all installed modules
cmd_update() {
    if [[ ! -d "$MODULES_DIR" ]]; then
        log_error "No modules installed. Run 'zd install' first."
        exit 1
    fi

    check_deps

    for module_dir in "$MODULES_DIR"/*/; do
        local module_name
        module_name=$(basename "$module_dir")
        log_info "Updating ${module_name}..."

        (cd "$module_dir" && git pull --ff-only 2>/dev/null) || {
            log_warn "Failed to update ${module_name}. You may need to resolve conflicts."
            continue
        }

        log_ok "Updated ${module_name}."
    done

    # Re-link after update
    cmd_link
}

# Show status of installed modules
cmd_status() {
    if [[ ! -d "$MODULES_DIR" ]]; then
        log_info "No modules installed."
        return
    fi

    echo ""
    log_info "Installed modules:"
    echo ""

    for module_dir in "$MODULES_DIR"/*/; do
        local module_name
        module_name=$(basename "$module_dir")
        local ref="unknown"
        local commit="unknown"

        if [[ -d "${module_dir}.git" ]]; then
            ref=$(cd "$module_dir" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")
            commit=$(cd "$module_dir" && git rev-parse --short HEAD 2>/dev/null || echo "?")
        fi

        echo -e "  ${GREEN}${module_name}${NC}  (${ref} @ ${commit})"

        # List skills
        if [[ -d "${module_dir}skills" ]]; then
            for skill_dir in "${module_dir}skills"/*/; do
                local skill_name
                skill_name=$(basename "$skill_dir")
                local link_status="unlinked"
                if [[ -L "${SHARED_SKILLS}/${skill_name}" ]]; then
                    link_status="linked"
                fi
                echo -e "    skill: ${skill_name} [${link_status}]"
            done
        fi

        # List agents
        if [[ -d "${module_dir}agents" ]]; then
            for agent_file in "${module_dir}agents"/*.md; do
                [[ -f "$agent_file" ]] || continue
                local agent_name
                agent_name=$(basename "$agent_file" .md)
                echo -e "    agent: ${agent_name}"
            done
        fi
    done
    echo ""
}

# Main dispatch
case "${1:-help}" in
    init)    cmd_init ;;
    install) cmd_install ;;
    link)    cmd_link ;;
    update)  cmd_update ;;
    status)  cmd_status ;;
    help|--help|-h)
        echo "Usage: zd <command>"
        echo ""
        echo "Commands:"
        echo "  init      Create starter zettledeck.yml and project structure"
        echo "  install   Install all modules from zettledeck.yml"
        echo "  update    Update installed modules to latest"
        echo "  link      Re-link skills and agents from installed modules"
        echo "  status    Show installed modules and link status"
        echo ""
        ;;
    *)
        log_error "Unknown command: $1"
        echo "Run 'zd help' for usage."
        exit 1
        ;;
esac
