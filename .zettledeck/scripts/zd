#!/usr/bin/env bash
#
# zd — ZettleDeck module composer
#
# Manages installation, updates, and tool wiring for ZettleDeck add-on modules.
# The core project is a template repo — this script handles add-on modules only.
#
# Usage:
#   zd install          Install all add-on modules declared in zettledeck.yml
#   zd update           Update all installed modules to latest
#   zd setup            Create tool wiring (symlinks, Kiro JSON, CLAUDE.md check)
#   zd status           Show installed modules and tool wiring state
#
# Requirements:
#   - git
#   - yq (https://github.com/mikefarah/yq) for YAML parsing
#     Install: brew install yq

set -euo pipefail

# Resolve project root: walk up from script location to find zettledeck.yml
find_project_root() {
    local dir
    dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
    if [[ -f "${dir}/zettledeck.yml" ]] || [[ -f "${dir}/.zettledeck/zettledeck.yml" ]]; then
        echo "$dir"
    else
        echo "$(pwd)"
    fi
}

PROJECT_ROOT="$(find_project_root)"
CONFIG_DIR="${PROJECT_ROOT}/.zettledeck"
CONFIG_FILE="${CONFIG_DIR}/zettledeck.yml"
INIT_STATE_FILE="${CONFIG_DIR}/init-state.yml"
SHARED_DIR="${PROJECT_ROOT}/.shared"
SHARED_SKILLS="${SHARED_DIR}/skills"
SHARED_AGENTS="${SHARED_DIR}/agents"
SHARED_STEERING="${SHARED_DIR}/steering"
SHARED_TEMPLATES="${SHARED_DIR}/templates"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()  { echo -e "${BLUE}[zd]${NC} $1"; }
log_ok()    { echo -e "${GREEN}[zd]${NC} $1"; }
log_warn()  { echo -e "${YELLOW}[zd]${NC} $1"; }
log_error() { echo -e "${RED}[zd]${NC} $1"; }

# Check dependencies
check_deps() {
    local bootstrap_script
    bootstrap_script="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/bootstrap"
    local missing=0

    if ! command -v git &>/dev/null; then
        log_error "git is required but not installed."
        log_info "  Download from: https://git-scm.com/downloads"
        missing=1
    fi

    if ! command -v yq &>/dev/null; then
        log_error "yq is required but not installed."
        missing=1
    fi

    if [[ $missing -eq 1 ]]; then
        echo ""
        if [[ -f "$bootstrap_script" ]]; then
            log_info "Run the bootstrap script to install missing dependencies automatically:"
            log_info "  ${bootstrap_script}"
        else
            log_info "Install missing dependencies manually:"
            log_info "  macOS:  brew install yq"
            log_info "  Linux:  https://github.com/mikefarah/yq/releases/latest"
        fi
        exit 1
    fi
}

# Ensure config file exists
require_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        log_error "No zettledeck.yml found at ${CONFIG_FILE}."
        log_info "If this is a fresh project from the template, create .zettledeck/zettledeck.yml"
        log_info "with your add-on module declarations."
        exit 1
    fi
}

# Ensure shared directories exist
ensure_shared_dirs() {
    mkdir -p "$SHARED_SKILLS" "$SHARED_AGENTS" "$SHARED_STEERING" "$SHARED_TEMPLATES"
}

# ─── Init State Management ─────────────────────────────────────────────────

# Ensure init-state.yml exists with base structure
ensure_init_state() {
    if [[ ! -f "$INIT_STATE_FILE" ]]; then
        cat > "$INIT_STATE_FILE" << 'EOF'
initialized: {}
pending: []
EOF
        log_info "Created init-state.yml"
    fi
}

# Record a module as installed (pending init) in init-state.yml
# Only adds to pending if not already initialized or pending
mark_module_installed() {
    local module_name="$1"

    ensure_init_state

    # Check if already initialized
    local is_initialized
    is_initialized=$(yq ".initialized.\"${module_name}\" // \"\"" "$INIT_STATE_FILE")
    if [[ -n "$is_initialized" && "$is_initialized" != "null" ]]; then
        log_info "  ${module_name} already initialized — skipping state update."
        return
    fi

    # Check if already pending
    local is_pending
    is_pending=$(yq ".pending[] | select(. == \"${module_name}\")" "$INIT_STATE_FILE")
    if [[ -n "$is_pending" ]]; then
        return
    fi

    # Add to pending
    yq -i ".pending += [\"${module_name}\"]" "$INIT_STATE_FILE"
    log_info "  Marked ${module_name} as pending init."
}

# Install a single module's assets from a cloned repo into .shared/
install_module_assets() {
    local module_dir="$1"
    local module_name="$2"
    local installed=0

    # Copy skills
    if [[ -d "${module_dir}/skills" ]]; then
        for skill_dir in "${module_dir}/skills"/*/; do
            [[ -d "$skill_dir" ]] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            local target="${SHARED_SKILLS}/${skill_name}"

            if [[ -d "$target" ]]; then
                log_warn "  Skill '${skill_name}' already exists. Skipping (use 'zd update' to refresh)."
                continue
            fi

            cp -R "$skill_dir" "$target"
            log_info "  Installed skill: ${skill_name}"
            installed=$((installed + 1))
        done
    fi

    # Copy agents
    if [[ -d "${module_dir}/agents" ]]; then
        for agent_file in "${module_dir}/agents"/*.md; do
            [[ -f "$agent_file" ]] || continue
            local agent_name
            agent_name=$(basename "$agent_file")
            local target="${SHARED_AGENTS}/${agent_name}"

            if [[ -f "$target" ]]; then
                log_warn "  Agent '${agent_name}' already exists. Skipping."
                continue
            fi

            cp "$agent_file" "$target"
            log_info "  Installed agent: ${agent_name}"
            installed=$((installed + 1))
        done
    fi

    # Copy steering files
    if [[ -d "${module_dir}/steering" ]]; then
        for steering_file in "${module_dir}/steering"/*.md; do
            [[ -f "$steering_file" ]] || continue
            local steering_name
            steering_name=$(basename "$steering_file")
            local target="${SHARED_STEERING}/${steering_name}"

            if [[ -f "$target" ]]; then
                log_warn "  Steering '${steering_name}' already exists. Skipping."
                continue
            fi

            cp "$steering_file" "$target"
            log_info "  Installed steering: ${steering_name}"
            installed=$((installed + 1))
        done
    fi

    # Copy templates
    if [[ -d "${module_dir}/templates" ]]; then
        for template_file in "${module_dir}/templates"/*; do
            [[ -f "$template_file" ]] || continue
            local template_name
            template_name=$(basename "$template_file")
            local target="${SHARED_TEMPLATES}/${template_name}"

            if [[ -f "$target" ]]; then
                log_info "  Template '${template_name}' already exists. Skipping (won't overwrite)."
                continue
            fi

            cp "$template_file" "$target"
            log_ok "  Installed template: ${template_name}"
            installed=$((installed + 1))
        done
    fi

    # Scaffold project-root directories (non-destructive)
    if [[ -d "${module_dir}/scaffolding" ]]; then
        while IFS= read -r -d '' raw_path; do
            local rel_path="${raw_path#./}"
            local target="${PROJECT_ROOT}/${rel_path}"
            if [[ -d "${module_dir}/scaffolding/${rel_path}" ]]; then
                if [[ ! -d "$target" ]]; then
                    mkdir -p "$target"
                    log_info "  Created directory: ${rel_path}"
                fi
            elif [[ -f "${module_dir}/scaffolding/${rel_path}" ]]; then
                if [[ ! -f "$target" ]]; then
                    mkdir -p "$(dirname "$target")"
                    cp "${module_dir}/scaffolding/${rel_path}" "$target"
                    log_info "  Scaffolded file: ${rel_path}"
                    installed=$((installed + 1))
                else
                    log_info "  Scaffold file '${rel_path}' already exists. Skipping."
                fi
            fi
        done < <(cd "${module_dir}/scaffolding" && find . -mindepth 1 \( -type f -o -type d \) -print0)
    fi

    # Copy module scripts
    if [[ -d "${module_dir}/scripts" ]]; then
        for script_file in "${module_dir}/scripts"/*; do
            [[ -f "$script_file" ]] || continue
            local script_name
            script_name=$(basename "$script_file")
            local target="${CONFIG_DIR}/scripts/${script_name}"

            if [[ -f "$target" ]]; then
                log_info "  Script '${script_name}' already exists. Skipping."
                continue
            fi

            cp "$script_file" "$target"
            chmod +x "$target"
            log_info "  Installed script: ${script_name}"
            installed=$((installed + 1))
        done
    fi

    # Copy init-steps.md to .zettledeck/{module-name}/init-steps.md
    if [[ -f "${module_dir}/init-steps.md" ]]; then
        local init_target_dir="${CONFIG_DIR}/${module_name}"
        mkdir -p "$init_target_dir"
        local init_target="${init_target_dir}/init-steps.md"
        if [[ ! -f "$init_target" ]]; then
            cp "${module_dir}/init-steps.md" "$init_target"
            log_info "  Installed init-steps: ${module_name}/init-steps.md"
            installed=$((installed + 1))
        else
            log_info "  init-steps for ${module_name} already exists. Skipping."
        fi
    fi

    # Copy note-rules.md to .zettledeck/{module-name}/note-rules.md
    if [[ -f "${module_dir}/note-rules.md" ]]; then
        local note_rules_target_dir="${CONFIG_DIR}/${module_name}"
        mkdir -p "$note_rules_target_dir"
        local note_rules_target="${note_rules_target_dir}/note-rules.md"
        if [[ ! -f "$note_rules_target" ]]; then
            cp "${module_dir}/note-rules.md" "$note_rules_target"
            log_info "  Installed note-rules: ${module_name}/note-rules.md"
            installed=$((installed + 1))
        else
            log_info "  note-rules for ${module_name} already exists. Skipping."
        fi
    fi

    # Deprecation check — doc-types.json replaced by module-config.json
    if [[ -f "${module_dir}/doc-types.json" ]]; then
        log_warn "  doc-types.json is deprecated — migrate to module-config.json. Skipping."
    fi

    # Merge module configuration into .zettledeck/core/config.json
    if [[ -f "${module_dir}/module-config.json" ]]; then
        merge_config "${module_dir}/module-config.json" "$module_name" "install"
    fi

    echo "$installed"
}

# Merge module configuration sections from module-config.json into core config.json.
#
# module-config.json declares one object per config section, each with:
#   mergeKey:          field that uniquely identifies an entry (e.g. "docType", "role")
#   preserveUserFields: fields zd never overwrites on update (e.g. "enabled", "folder")
#   entries:           array of objects to merge into the matching config section
#
# Mode "install": additive only — skip entries already registered (any source)
# Mode "update":  replace module-owned entries; skip "custom"; preserve user fields
merge_config() {
    local module_config_file="$1"
    local module_name="$2"
    local mode="$3"
    local core_config="${CONFIG_DIR}/core/config.json"

    if [[ ! -f "$core_config" ]]; then
        log_warn "  core/config.json not found — skipping config merge for ${module_name}."
        log_warn "  Run '/zettledeck.init core' first, then re-run 'zd install'."
        return
    fi

    # Enumerate top-level section keys declared in module-config.json
    local sections
    sections=$(yq 'keys | .[]' "$module_config_file")

    while IFS= read -r section; do
        [[ -z "$section" ]] && continue

        local merge_key entry_count preserve_fields
        merge_key=$(yq ".$section.mergeKey" "$module_config_file")
        entry_count=$(yq ".$section.entries | length" "$module_config_file")
        preserve_fields=$(yq ".$section.preserveUserFields // [] | .[]" "$module_config_file" 2>/dev/null || true)

        for ((t=0; t<entry_count; t++)); do
            local entry_key_val existing_entry existing_source entry_json
            entry_key_val=$(yq ".$section.entries[$t].$merge_key" "$module_config_file")
            existing_entry=$(yq ".$section[] | select(.$merge_key == \"${entry_key_val}\")" \
                "$core_config" 2>/dev/null || true)
            existing_source=$(yq ".$section[] | select(.$merge_key == \"${entry_key_val}\") | .source" \
                "$core_config" 2>/dev/null || true)

            if [[ "$mode" == "install" ]]; then
                if [[ -n "$existing_entry" && "$existing_entry" != "null" ]]; then
                    local src_display="${existing_source:-unknown}"
                    [[ "$src_display" == "null" ]] && src_display="unknown"
                    log_info "  [$section] '${entry_key_val}' already registered (source: ${src_display}). Skipping."
                    continue
                fi
                entry_json=$(yq -o=json ".$section.entries[$t]" "$module_config_file")
                yq -i ".$section += [${entry_json}]" "$core_config"
                log_ok "  [$section] Registered '${entry_key_val}' (source: ${module_name})"

            elif [[ "$mode" == "update" ]]; then
                if [[ "$existing_source" == "custom" ]]; then
                    log_info "  [$section] '${entry_key_val}' is custom — skipping (user owns it)."
                    continue
                fi
                if [[ -n "$existing_source" && "$existing_source" != "null" && \
                      "$existing_source" != "$module_name" ]]; then
                    log_info "  [$section] '${entry_key_val}' owned by '${existing_source}' — skipping."
                    continue
                fi

                entry_json=$(yq -o=json ".$section.entries[$t]" "$module_config_file")

                if [[ -z "$existing_source" || "$existing_source" == "null" ]]; then
                    yq -i ".$section += [${entry_json}]" "$core_config"
                    log_ok "  [$section] Registered '${entry_key_val}' (source: ${module_name})"
                else
                    # Save user-owned field values to a temp file before replacing the entry.
                    # Tab-delimited: field<TAB>value — one per line.
                    local preserve_tmpfile
                    preserve_tmpfile=$(mktemp)

                    while IFS= read -r field; do
                        [[ -z "$field" ]] && continue
                        local fval
                        fval=$(yq ".$section[] | select(.$merge_key == \"${entry_key_val}\") | .$field" \
                            "$core_config" 2>/dev/null || true)
                        [[ -n "$fval" && "$fval" != "null" ]] && printf '%s\t%s\n' "$field" "$fval" >> "$preserve_tmpfile"
                    done <<< "$preserve_fields"

                    # Replace the entry
                    yq -i "del(.$section[] | select(.$merge_key == \"${entry_key_val}\"))" "$core_config"
                    yq -i ".$section += [${entry_json}]" "$core_config"

                    # Restore user-owned fields.
                    # Booleans and numbers are written as literals; strings are quoted.
                    while IFS=$'\t' read -r field fval; do
                        if [[ "$fval" =~ ^(true|false|[0-9]+([.][0-9]+)?)$ ]]; then
                            yq -i "(.$section[] | select(.$merge_key == \"${entry_key_val}\") | .$field) = ${fval}" \
                                "$core_config"
                        else
                            yq -i "(.$section[] | select(.$merge_key == \"${entry_key_val}\") | .$field) = \"${fval}\"" \
                                "$core_config"
                        fi
                    done < "$preserve_tmpfile"
                    rm -f "$preserve_tmpfile"

                    log_info "  [$section] Updated '${entry_key_val}' (source: ${module_name})"
                fi
            fi
        done

    done <<< "$sections"
}

# ─── Commands ───────────────────────────────────────────────────────────────

# Install all modules from zettledeck.yml
cmd_install() {
    require_config
    check_deps
    ensure_shared_dirs

    local count
    count=$(yq '.modules | length' "$CONFIG_FILE")

    if [[ "$count" -eq 0 ]]; then
        log_info "No modules declared in zettledeck.yml."
        return
    fi

    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    for ((i=0; i<count; i++)); do
        local name repo ref
        name=$(yq ".modules[$i].name" "$CONFIG_FILE")
        repo=$(yq ".modules[$i].repo" "$CONFIG_FILE")
        ref=$(yq ".modules[$i].ref // \"main\"" "$CONFIG_FILE")

        log_info "Installing ${name} from ${repo} (${ref})..."

        local clone_dir="${tmpdir}/${name}"
        git clone --depth 1 --branch "$ref" "https://${repo}.git" "$clone_dir" 2>/dev/null || {
            log_error "Failed to clone ${repo}. Check the URL and your access."
            continue
        }

        install_module_assets "$clone_dir" "$name"
        mark_module_installed "$name"
        log_ok "Installed ${name}."
    done

    log_ok "Module installation complete."

    # Auto-wire any new agents for Kiro (skills/steering use directory symlinks
    # so they're already visible — only agents need per-file wiring)
    wire_kiro_agents || true

    log_info "Run '/zettledeck.init' to configure module-specific settings."
}

# Update all installed modules
cmd_update() {
    require_config
    check_deps
    ensure_shared_dirs

    local count
    count=$(yq '.modules | length' "$CONFIG_FILE")

    if [[ "$count" -eq 0 ]]; then
        log_info "No modules declared in zettledeck.yml."
        return
    fi

    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    for ((i=0; i<count; i++)); do
        local name repo ref
        name=$(yq ".modules[$i].name" "$CONFIG_FILE")
        repo=$(yq ".modules[$i].repo" "$CONFIG_FILE")
        ref=$(yq ".modules[$i].ref // \"main\"" "$CONFIG_FILE")

        log_info "Updating ${name} from ${repo} (${ref})..."

        local clone_dir="${tmpdir}/${name}"
        git clone --depth 1 --branch "$ref" "https://${repo}.git" "$clone_dir" 2>/dev/null || {
            log_error "Failed to clone ${repo}. Check the URL and your access."
            continue
        }

        # For update, overwrite existing assets
        if [[ -d "${clone_dir}/skills" ]]; then
            for skill_dir in "${clone_dir}/skills"/*/; do
                [[ -d "$skill_dir" ]] || continue
                local skill_name
                skill_name=$(basename "$skill_dir")
                rm -rf "${SHARED_SKILLS}/${skill_name}"
                cp -R "$skill_dir" "${SHARED_SKILLS}/${skill_name}"
                log_info "  Updated skill: ${skill_name}"
            done
        fi

        if [[ -d "${clone_dir}/agents" ]]; then
            for agent_file in "${clone_dir}/agents"/*.md; do
                [[ -f "$agent_file" ]] || continue
                local agent_name
                agent_name=$(basename "$agent_file")
                cp "$agent_file" "${SHARED_AGENTS}/${agent_name}"
                log_info "  Updated agent: ${agent_name}"
            done
        fi

        if [[ -d "${clone_dir}/steering" ]]; then
            for steering_file in "${clone_dir}/steering"/*.md; do
                [[ -f "$steering_file" ]] || continue
                local steering_name
                steering_name=$(basename "$steering_file")
                cp "$steering_file" "${SHARED_STEERING}/${steering_name}"
                log_info "  Updated steering: ${steering_name}"
            done
        fi

        if [[ -d "${clone_dir}/templates" ]]; then
            for template_file in "${clone_dir}/templates"/*; do
                [[ -f "$template_file" ]] || continue
                local template_name
                template_name=$(basename "$template_file")
                cp "$template_file" "${SHARED_TEMPLATES}/${template_name}"
                log_info "  Updated template: ${template_name}"
            done
        fi

        if [[ -d "${clone_dir}/scripts" ]]; then
            for script_file in "${clone_dir}/scripts"/*; do
                [[ -f "$script_file" ]] || continue
                local script_name
                script_name=$(basename "$script_file")
                cp "$script_file" "${CONFIG_DIR}/scripts/${script_name}"
                chmod +x "${CONFIG_DIR}/scripts/${script_name}"
                log_info "  Updated script: ${script_name}"
            done
        fi

        # Update init-steps.md (always overwrite — it's module-owned content)
        if [[ -f "${clone_dir}/init-steps.md" ]]; then
            local init_target_dir="${CONFIG_DIR}/${name}"
            mkdir -p "$init_target_dir"
            cp "${clone_dir}/init-steps.md" "${init_target_dir}/init-steps.md"
            log_info "  Updated init-steps: ${name}/init-steps.md"
        fi

        # Update note-rules.md (always overwrite — it's module-owned content)
        if [[ -f "${clone_dir}/note-rules.md" ]]; then
            local note_rules_target_dir="${CONFIG_DIR}/${name}"
            mkdir -p "$note_rules_target_dir"
            cp "${clone_dir}/note-rules.md" "${note_rules_target_dir}/note-rules.md"
            log_info "  Updated note-rules: ${name}/note-rules.md"
        fi

        # Deprecation check — doc-types.json replaced by module-config.json
        if [[ -f "${clone_dir}/doc-types.json" ]]; then
            log_warn "  doc-types.json is deprecated — migrate to module-config.json. Skipping."
        fi

        # Merge module configuration (update mode: replace module-owned, skip custom)
        if [[ -f "${clone_dir}/module-config.json" ]]; then
            merge_config "${clone_dir}/module-config.json" "$name" "update"
        fi

        # Scaffold project-root directories (non-destructive — never overwrite user content)
        if [[ -d "${clone_dir}/scaffolding" ]]; then
            while IFS= read -r -d '' raw_path; do
                local rel_path="${raw_path#./}"
                local target="${PROJECT_ROOT}/${rel_path}"
                if [[ -d "${clone_dir}/scaffolding/${rel_path}" ]]; then
                    if [[ ! -d "$target" ]]; then
                        mkdir -p "$target"
                        log_info "  Created directory: ${rel_path}"
                    fi
                elif [[ -f "${clone_dir}/scaffolding/${rel_path}" ]]; then
                    if [[ ! -f "$target" ]]; then
                        mkdir -p "$(dirname "$target")"
                        cp "${clone_dir}/scaffolding/${rel_path}" "$target"
                        log_info "  Scaffolded file: ${rel_path}"
                    fi
                fi
            done < <(cd "${clone_dir}/scaffolding" && find . -mindepth 1 \( -type f -o -type d \) -print0)
        fi

        log_ok "Updated ${name}."
    done

    log_ok "Module update complete."

    # Re-wire agents in case modules added or changed agent files
    wire_kiro_agents || true

    log_info "Run '/zettledeck.init' if updated modules have new init steps."
}

# ─── Tool Wiring ────────────────────────────────────────────────────────────

# Generate a Kiro agent JSON file from an agent markdown file
generate_kiro_agent_json() {
    local agent_md="$1"
    local agent_name
    agent_name=$(basename "$agent_md" .md)

    # Extract description from first non-empty, non-heading line
    local description
    description=$(grep -m1 -v '^#\|^$\|^---' "$agent_md" 2>/dev/null | head -c 200 || echo "ZettleDeck agent")

    cat << JSON
{
  "name": "${agent_name}",
  "description": "${description}",
  "agentFile": "${agent_name}.md"
}
JSON
}

# Wire Kiro agent symlinks + JSON companions for any agents in .shared/agents/
# Called by cmd_setup and automatically after cmd_install/cmd_update
wire_kiro_agents() {
    local kiro_dir="${PROJECT_ROOT}/.kiro"
    local wired=0

    [[ -d "$kiro_dir" ]] || return 0
    [[ -d "$SHARED_AGENTS" ]] || return 0

    mkdir -p "${kiro_dir}/agents"

    for agent_file in "${SHARED_AGENTS}"/*.md; do
        [[ -f "$agent_file" ]] || continue
        local agent_name
        agent_name=$(basename "$agent_file")
        local agent_base
        agent_base=$(basename "$agent_file" .md)

        # Symlink the .md file
        local md_target="${kiro_dir}/agents/${agent_name}"
        if [[ -L "$md_target" ]]; then
            rm "$md_target"
        fi
        ln -s "../../.shared/agents/${agent_name}" "$md_target"
        log_info "  Linked agent: ${agent_name}"

        # Generate the .json companion
        local json_target="${kiro_dir}/agents/${agent_base}.json"
        if [[ ! -f "$json_target" ]]; then
            generate_kiro_agent_json "$agent_file" > "$json_target"
            log_info "  Generated: ${agent_base}.json"
        fi

        ((wired++))
    done

    return "$wired"
}

# Setup tool wiring for Claude Code and/or Kiro
cmd_setup() {
    ensure_shared_dirs

    local claude_dir="${PROJECT_ROOT}/.claude"
    local kiro_dir="${PROJECT_ROOT}/.kiro"
    local wired=0

    # ── Claude Code ──────────────────────────────────────────────────────

    if [[ -d "$claude_dir" ]]; then
        log_info "Detected Claude Code. Setting up wiring..."
        mkdir -p "$claude_dir"

        # Symlink skills directory
        if [[ -L "${claude_dir}/skills" ]]; then
            rm "${claude_dir}/skills"
        fi
        if [[ ! -d "${claude_dir}/skills" ]]; then
            ln -s "../.shared/skills" "${claude_dir}/skills"
            log_info "  Linked .claude/skills → .shared/skills"
            wired=$((wired + 1))
        else
            log_warn "  .claude/skills exists as a directory. Skipping symlink."
        fi

        # Symlink agents directory
        if [[ -L "${claude_dir}/agents" ]]; then
            rm "${claude_dir}/agents"
        fi
        if [[ ! -d "${claude_dir}/agents" ]]; then
            ln -s "../.shared/agents" "${claude_dir}/agents"
            log_info "  Linked .claude/agents → .shared/agents"
            wired=$((wired + 1))
        else
            log_warn "  .claude/agents exists as a directory. Skipping symlink."
        fi

        log_ok "Claude Code wiring complete."
    fi

    # ── Kiro ─────────────────────────────────────────────────────────────

    if [[ -d "$kiro_dir" ]]; then
        log_info "Detected Kiro. Setting up wiring..."

        # Symlink skills directory
        if [[ -L "${kiro_dir}/skills" ]]; then
            rm "${kiro_dir}/skills"
        fi
        if [[ ! -d "${kiro_dir}/skills" ]]; then
            ln -s "../.shared/skills" "${kiro_dir}/skills"
            log_info "  Linked .kiro/skills → .shared/skills"
            wired=$((wired + 1))
        else
            log_warn "  .kiro/skills exists as a directory. Skipping symlink."
        fi

        # Symlink steering directory
        if [[ -L "${kiro_dir}/steering" ]]; then
            rm "${kiro_dir}/steering"
        fi
        if [[ ! -d "${kiro_dir}/steering" ]]; then
            ln -s "../.shared/steering" "${kiro_dir}/steering"
            log_info "  Linked .kiro/steering → .shared/steering"
            wired=$((wired + 1))
        else
            log_warn "  .kiro/steering exists as a directory. Skipping symlink."
        fi

        # Wire agent symlinks + JSON
        wire_kiro_agents || wired=$((wired + $?))

        log_ok "Kiro wiring complete."
    fi

    if [[ "$wired" -eq 0 ]]; then
        log_info "No tool directories detected (.claude/ or .kiro/)."
        log_info "Create .claude/ or .kiro/ first, then re-run 'zd setup'."
    else
        log_ok "Tool wiring complete. ${wired} items wired."
    fi

    # Install modules if a config is present
    if [[ -f "$CONFIG_FILE" ]]; then
        echo ""
        log_info "Module config found. Running install..."
        cmd_install
    fi
}

# ─── Status ─────────────────────────────────────────────────────────────────

cmd_status() {
    echo ""
    log_info "ZettleDeck Status"
    echo ""

    # Config
    if [[ -f "$CONFIG_FILE" ]]; then
        local count
        count=$(yq '.modules | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
        log_info "Config: ${CONFIG_FILE} (${count} modules declared)"
    else
        log_warn "Config: No zettledeck.yml found"
    fi

    # Installed skills
    echo ""
    log_info "Skills (.shared/skills/):"
    if [[ -d "$SHARED_SKILLS" ]]; then
        for skill_dir in "${SHARED_SKILLS}"/*/; do
            [[ -d "$skill_dir" ]] || continue
            echo -e "  ${GREEN}$(basename "$skill_dir")${NC}"
        done
    else
        echo "  (none)"
    fi

    # Installed agents
    echo ""
    log_info "Agents (.shared/agents/):"
    if [[ -d "$SHARED_AGENTS" ]]; then
        local found_agents=0
        for agent_file in "${SHARED_AGENTS}"/*.md; do
            [[ -f "$agent_file" ]] || continue
            echo -e "  ${GREEN}$(basename "$agent_file")${NC}"
            found_agents=1
        done
        [[ "$found_agents" -eq 0 ]] && echo "  (none)"
    else
        echo "  (none)"
    fi

    # Installed steering
    echo ""
    log_info "Steering (.shared/steering/):"
    if [[ -d "$SHARED_STEERING" ]]; then
        local found_steering=0
        for steering_file in "${SHARED_STEERING}"/*.md; do
            [[ -f "$steering_file" ]] || continue
            echo -e "  ${GREEN}$(basename "$steering_file")${NC}"
            found_steering=1
        done
        [[ "$found_steering" -eq 0 ]] && echo "  (none)"
    else
        echo "  (none)"
    fi

    # Init state
    echo ""
    log_info "Init State:"
    if [[ -f "$INIT_STATE_FILE" ]]; then
        # Show initialized modules
        local init_keys
        init_keys=$(yq '.initialized | keys | .[]' "$INIT_STATE_FILE" 2>/dev/null)
        if [[ -n "$init_keys" ]]; then
            echo -e "  Initialized:"
            while IFS= read -r key; do
                local date_val
                date_val=$(yq ".initialized.\"${key}\".date // .initialized.\"${key}\"" "$INIT_STATE_FILE" 2>/dev/null)
                echo -e "    ${GREEN}${key}${NC} (${date_val})"
            done <<< "$init_keys"
        else
            echo -e "  Initialized: ${YELLOW}(none)${NC}"
        fi

        # Show pending modules
        local pending_count
        pending_count=$(yq '.pending | length' "$INIT_STATE_FILE" 2>/dev/null || echo "0")
        if [[ "$pending_count" -gt 0 ]]; then
            echo -e "  Pending init:"
            for ((p=0; p<pending_count; p++)); do
                local pname
                pname=$(yq ".pending[$p]" "$INIT_STATE_FILE")
                echo -e "    ${YELLOW}${pname}${NC}"
            done
            echo ""
            log_info "Run '/zettledeck.init' to configure pending modules."
        fi
    else
        echo -e "  ${YELLOW}No init-state.yml found. Run 'zd install' or '/zettledeck.init' to create it.${NC}"
    fi

    # Document types by source
    echo ""
    log_info "Document Types (.zettledeck/core/config.json):"
    local core_config="${CONFIG_DIR}/core/config.json"
    if [[ -f "$core_config" ]]; then
        local dt_count
        dt_count=$(yq '.documentTypes | length' "$core_config" 2>/dev/null || echo "0")
        if [[ "$dt_count" -gt 0 ]]; then
            for ((d=0; d<dt_count; d++)); do
                local dt_name dt_source dt_prefix
                dt_name=$(yq ".documentTypes[$d].docType" "$core_config")
                dt_source=$(yq ".documentTypes[$d].source" "$core_config")
                dt_prefix=$(yq ".documentTypes[$d].prefix" "$core_config")
                echo -e "  ${GREEN}${dt_prefix}  ${dt_name}${NC}  (${dt_source})"
            done
        else
            echo "  (none — run '/zettledeck.init core' to configure)"
        fi
    else
        echo -e "  ${YELLOW}core/config.json not found${NC}"
    fi

    # Tool wiring
    echo ""
    log_info "Tool Wiring:"

    local claude_dir="${PROJECT_ROOT}/.claude"
    local kiro_dir="${PROJECT_ROOT}/.kiro"

    if [[ -d "$claude_dir" ]]; then
        echo -e "  Claude Code:"
        [[ -L "${claude_dir}/skills" ]] && echo -e "    skills: ${GREEN}linked${NC}" || echo -e "    skills: ${YELLOW}not linked${NC}"
        [[ -L "${claude_dir}/agents" ]] && echo -e "    agents: ${GREEN}linked${NC}" || echo -e "    agents: ${YELLOW}not linked${NC}"
        if [[ -f "${PROJECT_ROOT}/CLAUDE.md" ]] && grep -q '.shared/steering' "${PROJECT_ROOT}/CLAUDE.md" 2>/dev/null; then
            echo -e "    steering: ${GREEN}referenced in CLAUDE.md${NC}"
        else
            echo -e "    steering: ${YELLOW}not referenced in CLAUDE.md${NC}"
        fi
    else
        echo -e "  Claude Code: ${YELLOW}not detected${NC}"
    fi

    if [[ -d "$kiro_dir" ]]; then
        echo -e "  Kiro:"
        [[ -L "${kiro_dir}/skills" ]] && echo -e "    skills: ${GREEN}linked${NC}" || echo -e "    skills: ${YELLOW}not linked${NC}"
        [[ -L "${kiro_dir}/steering" ]] && echo -e "    steering: ${GREEN}linked${NC}" || echo -e "    steering: ${YELLOW}not linked${NC}"
        local kiro_agent_count=0
        for f in "${kiro_dir}/agents"/*.md; do
            [[ -L "$f" ]] && ((kiro_agent_count++))
        done
        echo -e "    agents: ${GREEN}${kiro_agent_count} linked${NC}"
    else
        echo -e "  Kiro: ${YELLOW}not detected${NC}"
    fi

    echo ""
}

# ─── Main Dispatch ──────────────────────────────────────────────────────────

case "${1:-help}" in
    install) cmd_install ;;
    update)  cmd_update ;;
    setup)   cmd_setup ;;
    status)  cmd_status ;;
    help|--help|-h)
        echo "Usage: zd <command>"
        echo ""
        echo "Commands:"
        echo "  install   Install add-on modules from zettledeck.yml"
        echo "  update    Update installed modules to latest"
        echo "  setup     Create tool wiring (Claude Code / Kiro symlinks)"
        echo "  status    Show installed modules and wiring status"
        echo ""
        ;;
    *)
        log_error "Unknown command: $1"
        echo "Run 'zd help' for usage."
        exit 1
        ;;
esac
